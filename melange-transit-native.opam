opam-version: "2.0"
version: "0.1.0"
synopsis: "Transit JSON reader and writer for native OCaml"
description:
  "melange-transit-native reads and writes Transit JSON values on native OCaml."
maintainer: ["rcmerci <rcmerci@gmail.com>"]
authors: ["rcmerci"]
license: "MIT"
homepage: "https://github.com/RCmerci/melange-transit"
bug-reports: "https://github.com/RCmerci/melange-transit/issues"
depends: [
  "dune" {>= "3.16"}
  "ocaml" {>= "5.2"}
  "melange-transit-core" {= version}
  "ptime"
  "qcheck" {with-test}
  "yojson"
  "odoc" {with-doc}
]
build: [
  ["dune" "subst"] {dev}
